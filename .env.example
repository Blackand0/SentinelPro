# Session secret for express-session (REQUIRED - change in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-key-here-change-in-production

# Node environment (development or production)
NODE_ENV=development

# Port (default: 5000 for local, 10000 for Render)
PORT=5000

# Database URL (optional - for PostgreSQL persistence)
# Format: postgresql://username:password@host:port/database
# Uncomment when using a database
# DATABASE_URL=

# Render deployment only:
# Set NODE_ENV=production and PORT=10000 when deploying to Render
