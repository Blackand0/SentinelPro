# Session secret for express-session (REQUIRED - change in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secret-key-here-change-in-production

# Node environment (development or production)
NODE_ENV=development

# Port (default: 5000 for local, 10000 for Render)
PORT=5000

# PostgreSQL Database Configuration
# For local development, configure your own PostgreSQL
# For Replit, these are automatically provided
DATABASE_URL=postgresql://user:password@host:port/database_name
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=database_name

# Render deployment only:
# When deploying to Render, set NODE_ENV=production and PORT=10000
# DATABASE_URL will be provided by Render PostgreSQL add-on
